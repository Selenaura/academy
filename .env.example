# SELENE ACADEMIA — Environment Variables
# ═══════════════════════════════════════════════

# Supabase (https://supabase.com → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # usado en webhook (no exponer en frontend)

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (crear en Stripe Dashboard → Products)
# STRIPE_PRICE_MAGNETISMO=price_...
# STRIPE_PRICE_ASTROLOGIA=price_...
# STRIPE_PRICE_CRONOBIOLOGIA=price_...
# STRIPE_PRICE_TAROT=price_...
# STRIPE_PRICE_MASTER=price_...

# Anthropic (para chatbot "Pregunta a Selene")
ANTHROPIC_API_KEY=sk-ant-...

# Site URL (para OAuth callbacks)
NEXT_PUBLIC_SITE_URL=https://academy.selenaura.com
